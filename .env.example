# Moduł ustawień Django (w docker-compose devowym używamy settings.local).
# DJANGO_SETTINGS_MODULE="django_bpp.settings.local"

# Jeżeli w pliku konfiguracyjnym podany zostanie URI do serwera LDAP,
# włączona zostanie autoryzacja LDAP. Będzie ona miała pierwszeństwo
# wobec autoryzacji z serwera bazowego tzn z bazy danych.
# AUTH_LDAP_SERVER_URI='ldap://127.0.0.1:11389'

# Użytkownik i hasło do podłączania się do serwera LDDAP
AUTH_LDAP_BIND_DN=ldap_user
AUTH_LDAP_BIND_PASSWORD=ldap_password

# Grupa przeszukiwana dla danego loginu
AUTH_LDAP_USER_SEARCH=ou=Pracownicy,dc=auth,dc=local

#
# Konfiguracja serwera pocztowego
#

# Konfiguracja serwera używanego do wysyłania poczty e-mail:
# EMAIL_URL=smtp+tls://uzytkownik:haslo@serwer:port/

# E-maile z alertami przychodzą do adminów od:
# SERVER_EMAIL=root@localhost

# E-maile wysyłane przez stronę domyślnie przychodzą od
# DEFAULT_FROM_EMAIL=webmaster@localhost

# Administratorzy strony
# ADMINS=Michał Pasternak <michal.dtz@gmail.com>

#
# Konfiguracja Worker/Concurrency
#

# Liczba workerów dla serwera aplikacji
# WEB_CONCURRENCY=4

#
# Konfiguracja bazy danych
#

# Wyłączenie SSL dla lokalnych/testowych środowisk
# DJANGO_BPP_DB_DISABLE_SSL=1

#
# Konfiguracja powiadomień Ofelia (scheduler/cron)
#

# SMTP configuration for Ofelia scheduled job notifications
# OFELIA_SMTP_HOST=smtp.example.com
# OFELIA_SMTP_PORT=587
# OFELIA_SMTP_USER=user@example.com
# OFELIA_SMTP_PASSWORD=password
# OFELIA_EMAIL_TO=admin@example.com
# OFELIA_EMAIL_FROM="Ofelia @ BPP <ofelia@bpp>"

# Slack webhook for Ofelia notifications
# OFELIA_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

#
# Konfiguracja backupów Rclone
#

# Rclone configuration is stored in the rclone_config volume
# Configure using: docker exec -it <container_name> rclone config

#
# Rollbar
#

# ROLLBAR_ACCESS_TOKEN="[token]"

#
# Docker exposed ports (defaults — odkomentuj, żeby zmienić)
#
# Uwaga: DJANGO_BPP_DB_PORT i DJANGO_BPP_REDIS_PORT
# są wspólne dla Dockera i Django — ich zmiana dotyczy obu.
#
# Testy używają testcontainers (losowe porty), więc nie kolidują z
# lokalnym dev-serverem na tych portach.
#

# DJANGO_BPP_DB_PORT=5432
# DJANGO_BPP_REDIS_PORT=6379
# DJANGO_BPP_PORT_APP=8000
# DJANGO_BPP_PORT_HTTP=1080
# DJANGO_BPP_PORT_HTTPS=10443
